# Patch: Decouple Tag Colors & Catppuccin Mocha Palette
# Author: kiqkuk
# Date: 2026-04-06
# Issue 1: Introduces 'colorTagSel' to decouple Active Tag colors from the Title bar.
# Issue 2: Implements Catppuccin Mocha color scheme for a consistent minimalist aesthetic.
# Issue 3: Optimizes 'renderTags' by removing redundant 'cairo_close_path' calls on line segments.
# Issue 4: Updates default font to 'Hack Nerd Font 10' for improved glyph support and scaling.
# Note: Users can further customize colors and font definitions in src/config.hpp.

diff --git a/src/bar.cpp b/src/bar.cpp
index 2f88fa3..76cbed3 100644
--- a/src/bar.cpp
+++ b/src/bar.cpp
@@ -242,7 +242,7 @@ void Bar::renderTags()
 {
 	for (auto &tag : _tags) {
 		setColorScheme(
-			tag.state & TagState::Active ? colorActive : colorInactive,
+			tag.state & TagState::Active ? colorTagSel : colorInactive,
 			tag.state & TagState::Urgent);
 		renderComponent(tag.component);
 		auto indicators = std::min(tag.numClients, static_cast<int>(_bufs->height/2));
@@ -250,7 +250,6 @@ void Bar::renderTags()
 			auto w = ind == tag.focusedClient ? 7 : 1;
 			cairo_move_to(_painter, tag.component.x, ind*2+0.5);
 			cairo_rel_line_to(_painter, w, 0);
-			cairo_close_path(_painter);
 			cairo_set_line_width(_painter, 1);
 			cairo_stroke(_painter);
 		}

diff --git a/src/config.def.hpp b/src/config.def.hpp
--- a/src/config.def.hpp
+++ b/src/config.def.hpp
@@ -10,10 +10,12 @@
 constexpr int paddingY = 3;
 
 // See https://docs.gtk.org/Pango/type_func.FontDescription.from_string.html
-constexpr const char* font = "Sans 12";
+constexpr const char* font = "Hack Nerd Font 10";
 
-constexpr ColorScheme colorInactive = {Color(0xbb, 0xbb, 0xbb), Color(0x22, 0x22, 0x22)};
-constexpr ColorScheme colorActive = {Color(0xee, 0xee, 0xee), Color(0x00, 0x55, 0x77)};
+// Catppuccin Mocha
+constexpr ColorScheme colorInactive = {Color(0xcb, 0xa6, 0xf7), Color(0x1e, 0x1e, 0x2e)};
+constexpr ColorScheme colorActive = {Color(0xcb, 0xa6, 0xf7), Color(0x1e, 0x1e, 0x2e)};
+constexpr ColorScheme colorTagSel = {Color(0x1e, 0x1e, 0x2e), Color(0xcb, 0xa6, 0xf7)};
 constexpr const char* termcmd[] = {"foot", nullptr};
 
 static std::vector<std::string> tagNames = {
