# --- ZSH COMPLETION ---
# Configures advanced Tab-completion with menu selection and case-insensitivity.

# Load system-wide zsh completions if available
autoload -Uz compinit && compinit

# Menu completion
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
