alias ..='cd ..'
alias ...='cd ../..'
alias mkdir='mkdir -p'

alias goshell='cd ~/.local/share/dots/shell'
alias goscript='cd ~/.local/share/dots/scripts'
alias godots='cd ~/.local/share/dots'

alias ls='ls --color=auto --group-directories-first'
alias grep='grep --color=auto'
alias ip='ip -color=auto'

alias rm='rm -iv'
alias cp='cp -iv'
alias mv='mv -iv'

alias up='sudo pacman -Syu'
alias cleanup='sudo pacman -Rns $(pacman -Qdtq); paccache -r -k 2'

# nvim / sudoedit
alias sudo='sudo '
nvim() {
  if [[ -n "$SUDO_COMMAND" ]]; then
    sudoedit "$@"
  else
    command nvim "$@"
  fi
}
