# --- ZSH MAIN CONFIGURATION ---
# Part of kiqkuk's dotfiles
# Handles environment and modular shell configs.

SHELLCONF="$HOME/.local/share/dots/shell"

# Load environment & PATH
[[ -f "$SHELLCONF/env" ]] && . "$SHELLCONF/env"

# Exit if not running interactively
[[ -o interactive ]] || return

# Load modular shell components
[[ -f "$SHELLCONF/completions" ]] && . "$SHELLCONF/completions"
[[ -f "$SHELLCONF/aliases" ]] && . "$SHELLCONF/aliases"
[[ -f "$SHELLCONF/prompt" ]] && . "$SHELLCONF/prompt"

# zsh-syntax-highlighting
[[ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && . /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
